{
  "name": "4ApiDestination",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "OPEN_STREETMAP": {
        "kind": "rest",
        "credentials": {
          "destination": "OPEN_STREETMAP"
        }
      },
      "COUNTRY_API": {
        "kind": "rest",
        "credentials": {
          "destination": "COUNTRY_API"
        }
      },
      "OPEN_METEO": {
        "kind": "rest",
        "credentials": {
          "destination": "OPEN_METEO"
        }
      }
    }
  }
}
